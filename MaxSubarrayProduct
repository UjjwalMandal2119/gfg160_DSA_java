class Solution {
    int maxProduct(int[] arr) {
        // code here
        int maxProduct =arr[0];
        
        for(int i=0; i<arr.length; i++){
            int product=arr[i];
            for(int j=i+1;j<arr.length; j++){
            product =product*arr[j];
            maxProduct=Math.max(maxProduct, product);
            }
        }
        return maxProduct;
    }
}
