class Solution {
    public int numSubarrayProductLessThanK(int[] arr, int k) {
        int si=0;
        int ei=0;
        int p=1;
        int ans =0;
        while(ei<arr.length){
            //growing
               p*=arr[ei];
            //Shrinking
            while(p>=k && si <=ei){
                p/=arr[si];
                si++;
            }   
            //answer calculate
            ans += (ei-si+1);
            ei++;
        }
        return ans;
    }
}
